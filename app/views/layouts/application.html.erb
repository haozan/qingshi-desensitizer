<!DOCTYPE html>
<html class="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
    <!-- stimulus-validator: allow-script -->
    <script>
      // Set dark mode immediately to prevent flash
      (function() {
        const storageKeys = ['demo-isdark', 'processor-isdark', 'admin-isdark'];
        // Check if any theme preference is saved
        let hasPreference = false;
        for (const key of storageKeys) {
          const saved = localStorage.getItem(key);
          if (saved !== null) {
            hasPreference = true;
            const isDark = JSON.parse(saved);
            if (isDark) {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
            break;
          }
        }
        // If no preference saved, default to dark and save it
        if (!hasPreference) {
          document.documentElement.classList.add('dark');
          for (const key of storageKeys) {
            localStorage.setItem(key, 'true');
          }
        }
      })();
    </script>
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#1D6E47">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="turbo-cache-control" content="no-cache">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="renderer" content="webkit">
    <meta http-equiv="cleartype" content="on">
    <meta name="HandheldFriendly" content="True">
    <meta name="MobileOptimized" content="320">
    <% if @disable_error_tracking %>
      <meta name="disable-error-tracking" content="true">
    <% end %>
    <title>
    <%- if content_for?(:title) %>
      <%= yield(:title) + ' | ' + Rails.application.config.x.appname %>
    <%- else %>
      <%= Rails.application.config.x.appname %>
    <%- end %>
    </title>
    <%= csrf_meta_tags %>
    <%= action_cable_meta_tag %>
    <%= og_meta_tags %>
    <%= content_for?(:head) ? yield(:head) : '' %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <!-- Load error handler early to catch all errors -->
    <%= javascript_include_tag 'error_handler' if Rails.env.development? %>
    <%= javascript_include_tag 'application', type: "module" %>
    <!-- Generate new favicon at `images/app-favicon.svg` at the first time, remove this line after generated  -->
    <%= favicon_link_tag asset_path("app-icon.png") unless Rails.env.test? %>
  </head>
  <body class="flex flex-col min-h-screen text-foreground <%= body_class %>">
    <!-- Top Banner for Qinglion AI -->
    <div class="w-full bg-primary text-surface py-2 px-4 text-center text-sm md:text-base">
      <a href="https://qingclaw.com" target="_blank" rel="noopener noreferrer" class="hover:underline flex items-center justify-center space-x-2">
        <span>律师用 AI，就用青狮龙虾</span>
        <%= lucide_icon "arrow-right", class: "w-4 h-4" %>
      </a>
    </div>
    <main class="flex-1 flex flex-col bg-surface">
      <%= render 'shared/navbar' unless @full_render %>
      <%= render 'shared/flash_messages' %>
      <%= yield %>
    </main>
    <% if Rails.env.development? %>
      <div id="system-monitor-stream"
           data-controller="system-monitor"
           data-system-monitor-signed-name-value="<%= Turbo::StreamsChannel.signed_stream_name("system_monitor") %>"
           data-turbo-permanent>
      </div>
    <% end %>
    <!-- stimulus-validator: allow-script -->
    <script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/service-worker.js')
        .then(registration => console.log('ServiceWorker registered:', registration.scope))
        .catch(error => console.error('ServiceWorker registration failed:', error));
    });
  }
</script>

  </body>
</html>
